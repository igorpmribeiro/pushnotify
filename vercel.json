{
  "installCommand": "npm install",
  "buildCommand": "npm run build -w packages/frontend",
  "outputDirectory": "packages/frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 10
    }
  }
}
